@model Core.Model.Recipes
@if(Model != null)
{
    @Html.AntiForgeryToken()

    <button type="button"
            onclick="handleToggleFavorite(event, this, @Model.RecipesId)"
            class="btn-favorite @(Model.IsFavorite ? "active" : "")">
        <i class="@(Model.IsFavorite ? "fa-solid" : "fa-regular") fa-heart"></i>
        <span class="fav-count">@Model.FavoriteCount</span>
    </button>   
}
