@model Core.Model.Recipes
@if(Model != null)
{
    bool isDetailView = ViewData["IsDetailView"] as bool? ?? false;

    <div class="favorite-info">
        <i class="fa-solid fa-heart"></i>
        <span>@Model.FavoriteCount</span>
    </div>

    @if (isDetailView)
    {
        @Html.AntiForgeryToken()

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            bool isFav = Model.IsFavorite;
            <button type="button"
                    class="btn-favorite-wook @(isFav ? "active" : "")"
                    onclick="handleToggleFavorite(event, this, @Model.RecipesId)"
                    title="@(isFav ? "Remover dos favoritos" : "Adicionar aos favoritos")">
                <i class="@(isFav ? "fa-solid" : "fa-regular") fa-heart"></i>
                <!-- Sem <span class="fav-badge"> aqui - sem contador no botão -->
            </button>
        }
        else
        {
            <button type="button" class="btn-favorite-wook disabled" title="Inicia sessão para guardar">
                <i class="fa-regular fa-heart"></i>
            </button>
        }
    }
}
