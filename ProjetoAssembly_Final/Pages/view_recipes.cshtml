@page "{id:int}"
@model ProjetoAssembly_Final.Pages.view_recipesModel
@using Microsoft.Extensions.Localization
@using System.Security.Claims
@inject IStringLocalizer<ProjetoAssembly_Final.Pages.view_recipesModel> Localizer
@{
    Layout = "_layout";
    ViewData["Title"] = Model.Recipe?.Title;

    var currentUserIdClaim = User.FindFirst(ClaimTypes.NameIdentifier);
    string? currentUserId = currentUserIdClaim?.Value;

    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    bool isAdmin = isAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Administrator"));
    bool isOwner = isAuthenticated 
                   && currentUserId != null 
                   && Model.Recipe?.UserId != null 
                   && Model.Recipe.UserId.ToString() == currentUserId;

    bool canEdit = isAdmin || isOwner;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/recipe.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/recipes-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/comments.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favorits.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/view-recipes.css" asp-append-version="true" />
}

<div id="antiforgery-token-container">
    @Html.AntiForgeryToken()
</div>

<main class="view-recipe-container">
    @if (Model.IsReviewMode)
    {
       <div class="alert alert-warning d-flex justify-content-between align-items-center mb-5 p-4 rounded-3 shadow-sm">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-circle-exclamation fa-2x me-3"></i>
                <div>
                    <strong>@Localizer["Modo de Revisão"]</strong><br />
                    @Localizer["Esta receita aguarda aprovação."]
                </div>
            </div>
            <div class="d-flex gap-3">
                <form method="post" asp-page="/PendingRecipes" asp-page-handler="Approve">
                    <input type="hidden" name="id" value="@Model.Recipe?.RecipesId" />
                    <button type="submit" class="btn-action btn-approve">
                        <i class="fa-solid fa-check"></i> @Localizer["Aprovar"]
                    </button>
                </form>
                <a asp-page="/PendingRecipes" class="btn-action" style="background: #6c757d; color: white;">
                    <i class="fa-solid fa-arrow-left"></i> @Localizer["Sair"]
                </a>
            </div>
        </div>
    }

    <div class="recipe-hero">
        <img src="/img/@(string.IsNullOrEmpty(Model.Recipe?.ImageUrl) ? "default.jpg" : Model.Recipe.ImageUrl)" alt="@Model.Recipe?.Title">
        <div class="hero-overlay">
            <h1 class="hero-title">@Model.Recipe?.Title</h1>

            <div class="hero-meta">
                <div class="hero-meta-item">
                    <i class="fa-solid fa-users"></i> @Model.Recipe?.Servings @Localizer["Doses"]
                </div>
                <div class="hero-meta-item">
                    <i class="fa-regular fa-clock"></i> @(Model.Recipe?.PrepTimeMinutes + Model.Recipe?.CookTimeMinutes) min
                </div>
                <div class="hero-meta-item">
                    <span class="difficulty-badge @(Model.Recipe?.DifficultyId == 1 ? "dif-easy" : Model.Recipe?.DifficultyId == 2 ? "dif-medium" : "dif-hard")">
                        @(Model.Recipe?.DifficultyId == 1 ? "Fácil" : Model.Recipe?.DifficultyId == 2 ? "Média" : "Difícil")
                    </span>
                </div>
            </div>

            <div class="hero-actions">
                @if (isAuthenticated)
                {
                    bool isFav = Model.Recipe?.IsFavorite ?? false;
                    <button type="button" class="btn-action btn-favorite @(isFav ? "active" : "")"
                            onclick="handleToggleFavorite(event, this, @Model.Recipe?.RecipesId)">
                        <i class="@(isFav ? "fa-solid" : "fa-regular") fa-heart"></i>
                        @(isFav ? Localizer["Favorito"] : Localizer["Favoritar"])
                    </button>
                }

                @if (canEdit)
                {
                    <a asp-page="/editRecipe" asp-route-id="@Model.Recipe?.RecipesId" class="btn-action btn-edit">
                        <i class="fa-solid fa-pen-to-square"></i> @Localizer["Editar Receita"]
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="recipe-main-content">
        <div class="ingredients-panel">
            <h3 class="section-title"><i class="fa-solid fa-list-ul"></i> @Localizer["Ingredientes"]</h3>
            <ul class="ingredients-list">
                @if (Model.Recipe?.Ingredients != null && Model.Recipe.Ingredients.Any())
                {
                    @foreach (var ing in Model.Recipe.Ingredients)
                    {
                        <li>
                            <i class="fa-solid fa-check check-icon"></i>
                            @ing.QuantityValue @ing.Unit @Localizer["de"] @(ing.Ingredient?.IngredientName ?? "Ingrediente")
                        </li>
                    }
                }
                else
                {
                    <li class="text-muted">@Localizer["Lista de ingredientes não disponível."]</li>
                }
            </ul>
        </div>

        <div class="instructions-panel">
            <h3 class="section-title"><i class="fa-solid fa-mitten"></i> @Localizer["Modo de Preparação"]</h3>
            <div class="instructions-text">
                @Model.Recipe?.Instructions
            </div>
        </div>
    </div>

    <hr class="separator-light mt-5 mb-5">

    <section class="comments-section">
        <h2 class="section-title"><i class="fa-solid fa-comments"></i> @Localizer["Comentários"]</h2>

        @if (!isAuthenticated)
        {
            <div class="empty-notice text-center py-5">
                <i class="fa-solid fa-lock fa-3x mb-3" style="color: var(--primary-green); opacity: 0.7;"></i>
                <h4>@Localizer["Quer deixar a sua opinião?"]</h4>
                <p>@Localizer["Apenas utilizadores registados podem comentar."]</p>
                <a asp-page="/login" class="btn-action btn-edit mt-3">@Localizer["Entrar para comentar"]</a>
            </div>
        }

        <partial name="_CommentsSection" model='new ProjetoAssembly_Final.Pages.Shared._CommentsSectionModel {
            ListComments = Model.ListComments,
            RecipeId = Model.Recipe?.RecipesId ?? 0
        }' />
    </section>
</main>

@section Scripts {
    <script src="~/js/favorites.js" asp-append-version="true"></script>
    <script src="~/js/comments.js" asp-append-version="true"></script>
}