@page
@model ProjetoAssembly_Final.Pages.MyFavoritsRecipesModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProjetoAssembly_Final.Pages.MyFavoritsRecipesModel> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Os Meus Favoritos"];   
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/myfavoritesrecipes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/recipes-card.css" asp-append-version="true" />    
}

<div class="favorites-page">
    <h1 class="favorites-title">
        <i class="fa-solid fa-heart text-danger"></i>
        @Localizer["Os Meus Favoritos"]
    </h1>
    <p class="favorites-subtitle">
        @Localizer["As receitas que guardaste com carinho ❤️"]
    </p>

    <div class="favorites-container">
        @if (Model.MyFavoriteRecipes != null && Model.MyFavoriteRecipes.Any())
        {
            <div class="favorites-grid">
                @foreach (var receita in Model.MyFavoriteRecipes)
                {
                    <partial name="_RecipesCard" model="receita" />
                }
            </div>
        }
        else
        {
            <div class="no-favorites">
                <i class="fa-regular fa-heart fa-5x"></i>
                <h2>@Localizer["Ainda não tens favoritos"]</h2>
                <p>@Localizer["Explora as receitas e clica no coração para guardar as tuas preferidas!"]</p>
                <a asp-page="/recipes" class="btn-explore">
                    <i class="fa-solid fa-search"></i>
                    @Localizer["Ver Receitas"]
                </a>
            </div>
        }
    </div>
</div>


