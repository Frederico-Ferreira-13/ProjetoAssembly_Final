@page
@model ProjetoAssembly_Final.Pages.settingsModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProjetoAssembly_Final.Pages.settingsModel> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Definições de Conta"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/settings.css" asp-append-version="true" />
}

<main class="container">
    <div class="settings-container">        
        <div class="settings-header">
            <i class="fa-solid fa-user-gear fa-2x"></i>
            <h2>@Localizer["Definições de Conta"]</h2>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form method="post">
            <div class="settings-section">
                <h4 class="section-title"><i class="fa-solid fa-address-card"></i> @Localizer["Dados Pessoais"]</h4>
                <div class="settings-grid">
                    <div class="form-group">
                        <label>@Localizer["Nome Completo"]</label>
                        <input type="text" asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>@Localizer["Nome de Utilizador"]</label>
                        <input type="text" asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="form-group full-width">
                        <label>@Localizer["Email"]</label>
                        <input type="email" asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4 class="section-title"><i class="fa-solid fa-sliders"></i> @Localizer["Preferências"]</h4>
                <div class="settings-grid">
                    <div class="form-group">
                        <label>@Localizer["Tema do Sistema"]</label>
                        <select asp-for="InputTheme" class="form-control">
                            <option value="Light">@Localizer["Modo Claro"]</option>
                            <option value="Dark">@Localizer["Modo Escuro"]</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>@Localizer["Idioma"]</label>
                        <select asp-for="InputLanguage" class="form-control">
                            <option value="pt-PT">Português (Portugal)</option>
                            <option value="en-US">English (US)</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="settings-section security-box">
                <h4 class="section-title"><i class="fa-solid fa-shield-halved"></i> @Localizer["Segurança"]</h4>
                <div class="settings-grid">
                    <div class="form-group full-width">
                        <label>@Localizer["Palavra-passe Atual"]</label>
                        <input type="password" asp-for="CurrentPassword" class="form-control" placeholder="@Localizer["Obrigatório para mudar a pass"]" />
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Nova Palavra-passe"]</label>
                        <input type="password" asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Confirmar Nova"]</label>
                        <input type="password" asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="settings-actions">
                <button type="submit" class="btn-save">
                    <i class="fa-solid fa-check"></i> @Localizer["Aplicar Alterações"]
                </button>
                <a asp-page="/perfil" class="btn-cancel">@Localizer["Voltar"]</a>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <script src="~/js/darkmode.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}