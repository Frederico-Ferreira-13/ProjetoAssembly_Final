@page
@model ProjetoAssembly_Final.Pages.IndexModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProjetoAssembly_Final.Pages.IndexModel> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Início"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/recipe.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/recipes-card.css" asp-append-version="true" />
}

<link rel="preload" as="image" href="@Url.Content("~/img/hero.jpg")">

<header class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1>@Localizer["Descubra o sabor de cozinhar em casa"]</h1>
        <p>@Localizer["As melhores iguarias, desde sopas reconfortantes a sobremesas irresistíveis."]</p>
        
        <div class="hero-actions">
            <a asp-page="/recipes" class="btn-principal btn-hero-primary">
                <i class="fa-solid fa-star"></i> 
                @Localizer["Ver Destaques da Semana"]
            </a>

            <a href="#categorias" class="btn-secundario">
                <i class="fa-solid fa-list-ul"></i>
                @Localizer["Explorar por Categoria"]
            </a>
        </div>       
    </div>
</header>

<main class="container">

    <section id="categorias" class="category-section">
        <h2 class="section-title-center">@Localizer["O que pretende cozinhas hoje?"]</h2>
        <div class="category-grid">
            <a asp-page="/recipes" asp-route-categoryId="1" class="category-card">
                <div class="cat-icon"><i class="fa-solid fa-bowl-food"></i></div>
                <span>@Localizer["Sopas"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="2" class="category-card">
                <div class="cat-icon"><i class="fa-solid fa-drumstick-bite"></i></div>
                <span>@Localizer["Carne"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="3" class="category-card">
                <div class="cat-icon"><i class="fa-solid fa-fish"></i></div>
                <span>@Localizer["Peixe"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="4" class="category-card">
                <div class="cat-icon"><i class="fa-solid fa-cake-candles"></i></div>
                <span>@Localizer["Sobremesas"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="5" class="category-card">
                <div class="cat-icon"><i class="fa-solid fa-leaf"></i></div>
                <span>@Localizer["Vegetariano"]</span>
            </a>                    
        </div>
    </section>
    
    <section class="slider-container">
        <div class="section-header">
            <h2 class="section-title">@Localizer["Destaques da Semana"]</h2>
        </div>
        
        <div class="slideshow-wrapper">
            @if (Model.RecipeList != null && Model.RecipeList.Any())
            {
                @for (int i = 0; i < Model.RecipeList.Count; i++)
                {
                    var recipe = Model.RecipeList[i];

                    var slideImg = string.IsNullOrEmpty(recipe.ImageUrl)
                    ? Url.Content("~/img/default.jpg")
                    : (recipe.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                    ? recipe.ImageUrl
                    : Url.Content("~/img/" + recipe.ImageUrl.Replace("img/", "").Replace("~/", "")));

                    var displayStyle = (i == 0) ? "display:block;" : "display:none;";

                    <div class="mySlides fade" style="@displayStyle">
                        <a asp-page="/view_recipes" asp-route-id="@recipe.RecipesId" class="slide-link">
                            <img src="@slideImg" alt="@recipe.Title">
                            <div class="slide-badge">@Localizer["Destaque"]</div>
                            <div class="slide-text-overlay">
                                <h3>@recipe.Title</h3>
                                <span class="btn-slide-view">@Localizer["Ver Receita"]</span>
                            </div>
                        </a>
                    </div>
                }

                <button class="prev" onclick="plusDivs(-1)" aria-label="Anterior">&#10094;</button>
                <button class="next" onclick="plusDivs(1)" aria-label="Próximo">&#10095;</button>
            }
            else
            {
                <div class="mySlides fade" style="display:block;">
                    <img src="~/img/default.jpg" alt="Sem destaques">
                    <div class="slide-text-overlay">@Localizer["Nenhuma receita disponível"]</div>
                </div>
            }
        </div>
    </section>

    <section class="recipe-recent-section">
        <div class="section-header">
            <h2 class="section-title">@Localizer["últimas Novidades"]</h2>
            <a asp-page="/recipes" class="view-all-link">
                @Localizer["Ver todas as receitas"] <i class="fa-solid fa-chevron-right"></i>
                </a>
        </div>
        
        <div id="recipe-container" class="recipe-grid">
            @if (Model.RecipeList != null && Model.RecipeList.Any())
            {
                @foreach (var recipe in Model.RecipeList.Take(5))
                {
                    <partial name="_RecipesCard" model="recipe" />
                }
            }
            else
            {
                <div class="empty-notice">
                    <i class="fa-solid fa-utensils"></i>
                    <p>@Localizer["Ainda não temos receitas recentes para mostrar."]</p>
                </div>
            }
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/js/recipe-actions.js" asp-append-version="true"></script>
    <script src="~/js/favorites.js" asp-append-version="true"></script>
}
