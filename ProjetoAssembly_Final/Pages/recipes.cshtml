@page
@model ProjetoAssembly_Final.Pages.recipesModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ProjetoAssembly_Final.Pages.recipesModel> Localizer
@{
    Layout = "_Layout";
    ViewData["Title"] = Localizer["Explorar Receitas"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/recipe.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/recipes-card.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/myfavoritesrecipes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/favoritesbottom.css" asp-append-version="true" />
}

<div id="antiforgery-token-container">
    @Html.AntiForgeryToken()
</div>

<div class="main-wrapper">
    <section class="category-section">
        <h2 class="section-title">@Localizer["Explorar Receitas"]</h2>
        <nav aria-label="@Localizer["Navegação de categorias"]" class="category-nav">
            <a asp-page="/recipes" class="category-item @(string.IsNullOrEmpty(Request.Query["categoryId"]) ? "active" : "")">               
                <div class="category-icon"><i class="fa-solid fa-list"></i></div>
                <span>@Localizer["Todas"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="1"
               class="category-item @(Request.Query["categoryId"] == "1" ? "active" : "")">
                <div class="category-icon"><i class="fa-solid fa-bowl-food"></i></div>
                <span>@Localizer["Sopas"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="2"
               class="category-item @(Request.Query["categoryId"] == "2" ? "active" : "")">
                <div class="category-icon"><i class="fa-solid fa-drumstick-bite"></i></div>
                <span>@Localizer["Carne"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="3"
               class="category-item @(Request.Query["categoryId"] == "3" ? "active" : "")">
                <div class="category-icon"><i class="fa-solid fa-fish"></i></div>
                <span>@Localizer["Peixe"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="4"
               class="category-item @(Request.Query["categoryId"] == "4" ? "active" : "")">
                <div class="category-icon"><i class="fa-solid fa-cake-candles"></i></div>
                <span>@Localizer["Sobremesas"]</span>
            </a>
            <a asp-page="/recipes" asp-route-categoryId="5"
               class="category-item @(Request.Query["categoryId"] == "5" ? "active" : "")">
                <div class="category-icon"><i class="fa-solid fa-leaf"></i></div>
                <span>@Localizer["Vegetariano"]</span>
            </a>           
        </nav>        
    </section>

    <hr class="separator-light">

   <section class="results-section">
        <!-- Barra de pesquisa + ordenação -->
        <div class="filters-bar mb-5">
            <form method="get" asp-page="/recipes" class="search-form">
                <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                <div class="input-group search-group">
                    <input type="text" name="search" value="@Model.Search" 
                           class="form-control search-input" 
                           placeholder="@Localizer["Pesquisar por nome, ingrediente..."]" 
                           aria-label="@Localizer["Pesquisar receitas"]" />
                    <button type="submit" class="btn-search" aria-label="@Localizer["Pesquisar"]">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </form>

            <div class="sort-options">
                <label for="sort">@Localizer["Ordenar por"]:</label>
                <select name="sort" id="sort" class="sort-select" onchange="this.form.closest('form').submit();">
                    @if (string.IsNullOrEmpty(Model.Sort))
                    {
                        <option value="" selected>@Localizer["Mais recentes"]</option>
                    }
                    else
                    {
                        <option value="">@Localizer["Mais recentes"]</option>
                    }

                    @if (Model.Sort == "popular")
                    {
                        <option value="popular" selected>@Localizer["Popularidade"]</option>
                    }
                    else
                    {
                        <option value="popular">@Localizer["Popularidade"]</option>
                    }

                    @if (Model.Sort == "time")
                    {
                        <option value="time" selected>@Localizer["Tempo de preparo"]</option>
                    }
                    else
                    {
                        <option value="time">@Localizer["Tempo de preparo"]</option>
                    }

                    @if (Model.Sort == "difficulty")
                    {
                        <option value="difficulty" selected>@Localizer["Dificuldade"]</option>
                    }
                    else
                    {
                        <option value="difficulty">@Localizer["Dificuldade"]</option>
                    }
                </select>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Search))
        {
            var count = Model.ListRecipes?.Count() ?? 0;

            <div class="search-info mb-4">
                @Localizer["Resultados para"] <strong>"@Model.Search"</strong>
                <span class="result-count">(@count) @Localizer["receitas encontradas"]</span>
            </div>
        }

        <div id="container-recipe" class="recipe-grid">
            @if (Model.ListRecipes != null && Model.ListRecipes.Any())
            {
                @foreach (var receita in Model.ListRecipes)
                {
                    <partial name="_RecipesCard" model="receita" />
                }
            }
            else
            {
                <div class="empty-notice text-center py-5">
                    <i class="fa-solid fa-utensils-slash fa-5x mb-4" style="color: var(--primary-green); opacity: 0.7;"></i>
                    <h3>@Localizer["Nenhuma receita encontrada"]</h3>
                    <p class="text-muted mb-4 lead">
                        @Localizer["Não encontramos receitas com os critérios selecionados."]<br />
                        @Localizer["Tenta pesquisar com outros termos ou limpar os filtros."]
                    </p>
                    <div class="empty-actions mt-4">
                        <a asp-page="/createRecipe" class="btn btn-success btn-lg me-3">
                            <i class="fa-solid fa-plus me-2"></i> @Localizer["Criar Nova Receita"]
                        </a>
                        <a asp-page="/recipes" class="btn btn-outline-secondary btn-lg">
                            @Localizer["Ver Todas as Receitas"]
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Paginação moderna -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="@Localizer["Paginação de receitas"]" class="pagination-modern mt-5">
                <ul class="pagination-list">
                    <li class="@(Model.P <= 1 ? "disabled" : "")">
                        <a asp-page="/recipes" 
                           asp-route-p="@(Model.P - 1)" 
                           asp-route-categoryId="@Model.CategoryId" 
                           asp-route-search="@Model.Search"
                           asp-route-sort="@Model.Sort">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = Math.Max(1, Model.P - 2); i <= Math.Min(Model.TotalPages, Model.P + 2); i++)
                    {
                        <li class="@(i == Model.P ? "active" : "")">
                            <a asp-page="/recipes" 
                               asp-route-p="@i" 
                               asp-route-categoryId="@Model.CategoryId" 
                               asp-route-search="@Model.Search"
                               asp-route-sort="@Model.Sort">@i</a>
                        </li>
                    }

                    @if (Model.P + 3 < Model.TotalPages)
                    {
                        <li class="dots">...</li>
                        <li>
                            <a asp-page="/recipes" 
                               asp-route-p="@Model.TotalPages" 
                               asp-route-categoryId="@Model.CategoryId" 
                               asp-route-search="@Model.Search"
                               asp-route-sort="@Model.Sort">@Model.TotalPages</a>
                        </li>
                    }

                    <li class="@(Model.P >= Model.TotalPages ? "disabled" : "")">
                        <a asp-page="/recipes" 
                           asp-route-p="@(Model.P + 1)" 
                           asp-route-categoryId="@Model.CategoryId" 
                           asp-route-search="@Model.Search"
                           asp-route-sort="@Model.Sort">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </section>
</div>

@section Scripts {
    <script src="~/js/recipe-actions.js" asp-append-version="true"></script>    
}
